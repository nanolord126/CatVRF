# ВНИМАНИЕ: Использование .env запрещено (Zero Trust 2026). Используйте Doppler.

# === SECURITY FLAGS (обязательно выставить в prod) ===
# Отключить header-based tenant resolver (X-Tenant-ID) на проде!
TENANT_HEADER_RESOLVER=false

# === CENTRAL DOMAIN ===
CENTRAL_DOMAIN=catvrf.ru
CENTRAL_ADMIN_DOMAIN=admin.catvrf.ru

# === FLIGHT SEARCH EXTERNAL APIS ===
FLIGHT_SEARCH_PROVIDER=amadeus

# Amadeus API
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_TIMEOUT=30

# Sabre API
SABRE_API_KEY=your_sabre_api_key
SABRE_API_SECRET=your_sabre_api_secret
SABRE_BASE_URL=https://api.test.sabre.com
SABRE_TIMEOUT=30

# Skyscanner API
SKYSCANNER_API_KEY=your_skyscanner_api_key
SKYSCANNER_BASE_URL=https://partners.api.skyscanner.net
SKYSCANNER_TIMEOUT=30

# Flight Search Cache & Fallback
FLIGHT_SEARCH_CACHE_ENABLED=true
FLIGHT_SEARCH_CACHE_TTL=1800
FLIGHT_SEARCH_FALLBACK_ENABLED=true
FLIGHT_SEARCH_MAX_RETRIES=3
FLIGHT_SEARCH_RETRY_DELAY=1000

# Flight Search Rate Limiting
FLIGHT_SEARCH_RATE_LIMIT_ENABLED=true
FLIGHT_SEARCH_MAX_REQUESTS=100
FLIGHT_SEARCH_PER_MINUTES=60

# === CLICKHOUSE QUOTA ANALYTICS ===
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=catvrf_analytics
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_TIMEOUT=30
CLICKHOUSE_CONNECT_TIMEOUT=10

# === PROMETHEUS METRICS ===
# Storage driver: "redis" (production) or "memory" (development)
PROMETHEUS_STORAGE_DRIVER=redis
# Redis connection for metrics storage
PROMETHEUS_REDIS_CONNECTION=default
# Metrics route configuration
PROMETHEUS_ROUTE_ENABLED=true
PROMETHEUS_ROUTE_PREFIX=metrics
PROMETHEUS_ROUTE_MIDDLEWARE=auth:landlord,throttle:metrics
# Metrics namespace (all metrics will be prefixed with this)
PROMETHEUS_NAMESPACE=catvrf
# Redis prefix for metrics storage
PROMETHEUS_REDIS_PREFIX=prometheus:
# Metrics retention (set to null for no expiration)
PROMETHEUS_REDIS_TTL=null
# Enable metrics retention (optional)
PROMETHEUS_RETENTION_ENABLED=false
PROMETHEUS_RETENTION_TTL_DAYS=7

# === PAYMENT GATEWAY CONFIGURATION ===
# YooKassa Payment Gateway
YOOKASSA_API_KEY=your_yookassa_api_key
YOOKASSA_SHOP_ID=your_yookassa_shop_id

# Tinkoff Payment Gateway
TINKOFF_TERMINAL_KEY=your_tinkoff_terminal_key
TINKOFF_PASSWORD=your_tinkoff_password

# === PAYMENT ENGINE CONFIGURATION ===
# Enable new PaymentEngineService (gradual rollout)
PAYMENT_NEW_ENGINE_ENABLED=false
# Enable async fraud detection
PAYMENT_ASYNC_FRAUD_ENABLED=true
# Enable circuit breaker
PAYMENT_CIRCUIT_BREAKER_ENABLED=true
# Fraud amount threshold (in kopecks, default: 5,000,000 = 50,000 RUB)
PAYMENT_FRAUD_AMOUNT_THRESHOLD=5000000
# Idempotency key TTL in seconds (default: 86400 = 24 hours)
PAYMENT_IDEMPOTENCY_TTL=86400
# Gateway timeout in seconds (default: 5)
PAYMENT_GATEWAY_TIMEOUT=5
# Maximum gateway retry attempts (default: 3)
PAYMENT_GATEWAY_MAX_RETRIES=3
# Circuit breaker failure threshold (default: 5)
PAYMENT_CIRCUIT_BREAKER_THRESHOLD=5
# Circuit breaker timeout in seconds (default: 60)
PAYMENT_CIRCUIT_BREAKER_TIMEOUT=60

# === PAYMENT QUEUE CONFIGURATION ===
# Queue for payment fraud checks
PAYMENT_FRAUD_CHECK_QUEUE=payment-fraud-check
# Queue for payment reconciliation
PAYMENT_RECONCILIATION_QUEUE=payment-reconciliation

# === PAYMENT RECONCILIATION ===
# Enable daily reconciliation with gateways
PAYMENT_RECONCILIATION_ENABLED=false
# Reconciliation schedule (cron format, default: 0 2 * * * = 2 AM daily)
PAYMENT_RECONCILIATION_SCHEDULE=0 2 * * *
# Lookback period in days for reconciliation (default: 7)
PAYMENT_RECONCILIATION_LOOKBACK_DAYS=7

# === PAYMENT WEBHOOK CONFIGURATION ===
# Enable HMAC signature verification
PAYMENT_WEBHOOK_VERIFY_HMAC=true
# Replay protection window in seconds (default: 300 = 5 minutes)
PAYMENT_WEBHOOK_REPLAY_WINDOW=300

