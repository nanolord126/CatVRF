{
  "dashboard": {
    "title": "CatVRF Payments Health",
    "tags": ["catvrf", "payments", "monitoring"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Payment Success Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(catvrf_payment_payment_success_total[5m]) / (rate(catvrf_payment_payment_success_total[5m]) + rate(catvrf_payment_payment_failed_total[5m])) * 100",
            "legendFormat": "Success Rate",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 95},
                {"color": "green", "value": 99}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Payment Latency (P95)",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(catvrf_payment_payment_latency_seconds_bucket[5m]))",
            "legendFormat": "P95 Latency",
            "refId": "A"
          }
        ],
        "options": {
          "orientation": "auto",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0,
            "max": 10,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 3}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Fraud Block Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate(catvrf_payment_payment_fraud_blocked_total[5m]) / rate(catvrf_payment_payment_attempts_total[5m]) * 100",
            "legendFormat": "Fraud Block Rate",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 10,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.5},
                {"color": "red", "value": 2}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Active Circuit Breakers",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "count(catvrf_payment_circuit_breaker_state{state=\"open\"})",
            "legendFormat": "Open Circuits",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "red", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Payment Success Rate by Vertical",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(catvrf_payment_payment_success_total[5m]) / (rate(catvrf_payment_payment_success_total[5m]) + rate(catvrf_payment_payment_failed_total[5m])) * 100",
            "legendFormat": "{{vertical_code}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Gateway Success Rate by Provider",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(catvrf_payment_gateway_success_total[5m]) / (rate(catvrf_payment_gateway_success_total[5m]) + rate(catvrf_payment_gateway_failed_total[5m])) * 100",
            "legendFormat": "{{provider}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Payment Attempts (Last Hour)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "rate(catvrf_payment_payment_attempts_total[5m])",
            "legendFormat": "{{vertical_code}} - {{tenant_id}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Wallet Balance Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "catvrf_payment_wallet_balance_kopecks",
            "legendFormat": "{{tenant_id}} - {{wallet_id}}",
            "refId": "A"
          }
        ],
        "options": {
          "calculate": false,
          "color": {
            "scheme": "Spectral"
          },
          "exemplars": {
            "color": "rgba(255,0,255,0.7)"
          },
          "legend": {
            "showLegend": true
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyRUB",
            "decimals": 2
          }
        }
      },
      {
        "id": 9,
        "title": "Payment Latency Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "rate(catvrf_payment_payment_latency_seconds_bucket[5m])",
            "legendFormat": "{{vertical_code}} - {{provider}}",
            "refId": "A"
          }
        ],
        "options": {
          "calculate": false,
          "color": {
            "scheme": "Oranges"
          },
          "exemplars": {
            "color": "rgba(255,0,255,0.7)"
          },
          "legend": {
            "showLegend": true
          }
        }
      },
      {
        "id": 10,
        "title": "Fraud Blocks by Type",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "sum by (fraud_type) (increase(catvrf_payment_payment_fraud_blocked_total[1h]))",
            "legendFormat": "{{fraud_type}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          },
          "pieType": "pie"
        }
      }
    ]
  }
}
