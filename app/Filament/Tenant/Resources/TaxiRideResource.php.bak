<?php

declare(strict_types=1);

namespace App\Filament\Tenant\Resources;

use App\Domains\Auto\Models\TaxiRide;
use App\Domains\Auto\Models\Vehicle;
use App\Domains\Auto\Services\TaxiService;
use App\Filament\Tenant\Resources\TaxiRideResource\Pages;
use Filament\Forms;
use Filament\Forms\Form;
use Filament\Resources\Resource;
use Filament\Tables;
use Filament\Tables\Table;
use Illuminate\Database\Eloquent\Builder;
use Illuminate\Support\Str;

/**
 * КАНОН 2026: TaxiRideResource.
 * Управление поездками такси (Fleet Management).
 */
final class TaxiRideResource extends Resource
{
    protected static ?string $model = TaxiRide;

    protected static ?string $navigationIcon = 'heroicon-o-cursor-arrow-rays';
    
    protected static ?string $navigationGroup = 'Такси и Доставка';

    protected static ?string $slug = 'fleet/taxi/rides';

    protected static ?string $label = 'Поездка';
    
    protected static ?string $pluralLabel = 'Поездки такси';

    /**
     * Форма создания/редактирования поездки.
     */
    public static function form(Form $form): Form
    {
        return $form
            ->schema([
                Forms\Components\Section::make('Маршрут и Клиент')
                    ->schema([
                        Forms\Components\Select::make('passenger_id')
                            ->relationship('passenger', 'name')
                            ->searchable()
                            ->preload()
                            ->required()
                            ->label('Пассажир'),
                        Forms\Components\TextInput::make('pickup_address')
                            ->required()
                            ->label('Откуда'),
                        Forms\Components\TextInput::make('dropoff_address')
                            ->required()
                            ->label('Куда'),
                        Forms\Components\Select::make('status')
                            ->options([
                                'searching' => 'Поиск водителя',
                                'accepted' => 'Принято',
                                'arrived' => 'В пути',
                                'finished' => 'Завершено',
                                'cancelled' => 'Отменено',
                            ])
                            ->default('searching')
                            ->required()
                            ->label('Статус'),
                    ])->columns(2),

                Forms\Components\Section::make('Экипаж')
                    ->schema([
                        Forms\Components\Select::make('vehicle_id')
                            ->relationship('vehicle', 'license_plate', function (Builder $query) {
                                return $query->where('status', 'active');
                            })
                            ->searchable()
                            ->preload()
                            ->label('Автомобиль'),
                        Forms\Components\Select::make('driver_id')
                            ->relationship('driver', 'name')
                            ->searchable()
                            ->label('Водитель'),
                    ])->columns(2),

                Forms\Components\Section::make('Стоимость')
                    ->schema([
                        Forms\Components\TextInput::make('total_cost_kopecks')
                            ->numeric()
                            ->default(0)
                            ->label('Стоимость (копейки)'),
                        Forms\Components\TextInput::make('surge_multiplier')
                            ->numeric()
                            ->default(1.0)
                            ->step(0.1)
                            ->label('Коэффициент (Surge)'),
                    ])->columns(2),

                Forms\Components\Section::make('Дополнительно')
                    ->schema([
                        Forms\Components\Placeholder::make('correlation_id')
                            ->content(fn ($record) => $record?->correlation_id ?? 'N/A')
                            ->label('Correlation ID'),
                        Forms\Components\KeyValue::make('tags')
                            ->label('Теги поездки (JSON)'),
                    ]),
            ]);
    }

    /**
     * Таблица поездок.
     */
    public static function table(Table $table): Table
    {
        return $table
            ->columns([
                Tables\Columns\TextColumn::make('passenger.name')
                    ->sortable()
                    ->label('Пассажир'),
                Tables\Columns\TextColumn::make('vehicle.license_plate')
                    ->label('Авто'),
                Tables\Columns\BadgeColumn::make('status')
                    ->colors([
                        'warning' => 'searching',
                        'primary' => 'accepted',
                        'info' => 'arrived',
                        'success' => 'finished',
                        'danger' => 'cancelled',
                    ])
                    ->label('Статус'),
                Tables\Columns\TextColumn::make('total_cost_kopecks')
                    ->money('RUB', divisor: 100)
                    ->label('Цена'),
                Tables\Columns\TextColumn::make('accepted_at')
                    ->dateTime()
                    ->sortable()
                    ->toggleable(isToggledHiddenByDefault: true)
                    ->label('Принято в'),
                Tables\Columns\TextColumn::make('created_at')
                    ->dateTime()
                    ->sortable()
                    ->label('Создано'),
            ])
            ->filters([
                Tables\Filters\SelectFilter::make('status'),
            ])
            ->actions([
                Tables\Actions\EditAction::make(),
                Tables\Actions\Action::make('complete')
                    ->label('Завершить')
                    ->icon('heroicon-o-check-circle')
                    ->color('success')
                    ->requiresConfirmation()
                    ->visible(fn ($record) => $record->status === 'arrived')
                    ->action(fn ($record) => app(TaxiService::class)->completeRide($record, Str::uuid()->toString())),
            ])
            ->bulkActions([
                Tables\Actions\DeleteBulkAction::make(),
            ]);
    }

    public static function getPages(): array
    {
        return [
            'index' => Pages\ListTaxiRides::route('/'),
            'create' => Pages\CreateTaxiRide::route('/create'),
            'edit' => Pages\EditTaxiRide::route('/{record}/edit'),
        ];
    }
}
