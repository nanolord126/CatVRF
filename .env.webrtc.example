# ════════════════════════════════════════════════════════════════════════════════
# WEBRTC & LIVE STREAMING CONFIGURATION (March 2026)
# ════════════════════════════════════════════════════════════════════════════════

# Broadcasting Driver for Live Streaming Mesh
# Options: reverb | pusher | ably | redis
BROADCAST_DRIVER=reverb

# ────────────────────────────────────────────────────────────────────────────────
# REVERB (Native Laravel WebSocket Server)
# ────────────────────────────────────────────────────────────────────────────────
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_APP_ID=laravel
REVERB_APP_KEY=your-app-key
REVERB_APP_SECRET=your-app-secret

# ────────────────────────────────────────────────────────────────────────────────
# WebRTC STUN/TURN Servers (for NAT Traversal)
# ────────────────────────────────────────────────────────────────────────────────
# STUN (Session Traversal Utilities for NAT) - usually free
WEBRTC_STUN=stun:stun.l.google.com:19302

# TURN (Traversal Using Relays around NAT) - relay server when P2P fails
# Critical for 70% of users behind symmetric NAT
# Options: coturn (self-hosted), Twilio, xirsys, etc.
WEBRTC_TURN_URL=turn:your-turn-server:3478
WEBRTC_TURN_USERNAME=your-username
WEBRTC_TURN_CREDENTIAL=your-credential

# ════════════════════════════════════════════════════════════════════════════════
# SELF-HOSTED TURN SERVER (coturn) - RECOMMENDED FOR PRODUCTION
# ════════════════════════════════════════════════════════════════════════════════
# Install: apt-get install coturn
# Config: /etc/coturn/turnserver.conf
# Start: systemctl start coturn
# 
# Basic turnserver.conf:
# ────────────────────────
# listening-port=3478
# listening-ip=0.0.0.0
# realm=example.com
# user=username:credential
# external-ip=YOUR_PUBLIC_IP/YOUR_PRIVATE_IP
# cipher-list="ECDHE-RSA-AES128-GCM-SHA256 ECDHE-RSA-AES256-GCM-SHA384"
# log-file=/var/log/coturn/turnserver.log
# ════════════════════════════════════════════════════════════════════════════════
