CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Cache TTL settings (in minutes)
CACHE_B2B_MODE_TTL=60
CACHE_RESPONSE_TTL=10
CACHE_USER_TASTE_TTL=30
CACHE_POPULAR_PRODUCTS_TTL=240
CACHE_MASTER_AVAILABILITY_TTL=120
CACHE_VERTICAL_STATS_TTL=480

# Queue settings
QUEUE_RETRY_AFTER=30
QUEUE_TIMEOUT=600
HORIZON_PATH=/horizon
