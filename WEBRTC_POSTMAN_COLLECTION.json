{
  "info": {
    "name": "WebRTC Mesh Live Streaming API",
    "description": "Postman collection for testing Reverb + Laravel WebRTC P2P streaming",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Join Stream",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "X-CSRF-Token",
            "value": "{{csrf_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"peer_id\": \"peer_{{$timestamp}}_{{$randomString}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/mesh/join",
          "protocol": "http",
          "host": ["{{base_url}}"],
          "path": ["mesh", "join"]
        },
        "description": "Присоединиться к стриму и получить TURN конфигурацию"
      },
      "response": []
    },
    {
      "name": "2. Send Offer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-CSRF-Token",
            "value": "{{csrf_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"from_peer\": \"peer_123456\",\n  \"to_peer\": \"peer_789012\",\n  \"sdp\": \"v=0\\r\\no=- {{$timestamp}} 2 IN IP4 127.0.0.1\\r\\ns=-\\r\\nt=0 0\\r\\na=group:BUNDLE 0 1\\r\\na=msid-semantic: WMS stream\\r\\nm=audio 1 RTP/SAVPF 111\\r\\na=rtcp:9 IN IP4 0.0.0.0\\r\\na=ice-ufrag:abcd\\r\\na=ice-pwd:abcdefghijklmnopqrstuvwxyz\\r\\na=fingerprint:sha-256 00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00\\r\\na=setup:actpass\\r\\na=mid:0\\r\\na=sendrecv\\r\\na=rtcp-mux\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/mesh/offer",
          "protocol": "http",
          "host": ["{{base_url}}"],
          "path": ["mesh", "offer"]
        },
        "description": "Отправить SDP offer от одного пира другому"
      },
      "response": []
    },
    {
      "name": "3. Send Answer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-CSRF-Token",
            "value": "{{csrf_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"from_peer\": \"peer_789012\",\n  \"to_peer\": \"peer_123456\",\n  \"sdp\": \"v=0\\r\\no=- {{$timestamp}} 2 IN IP4 127.0.0.1\\r\\ns=-\\r\\nt=0 0\\r\\na=group:BUNDLE 0 1\\r\\na=msid-semantic: WMS stream\\r\\nm=audio 1 RTP/SAVPF 111\\r\\na=rtcp:9 IN IP4 0.0.0.0\\r\\na=ice-ufrag:efgh\\r\\na=ice-pwd:ijklmnopqrstuvwxyzabcdefgh\\r\\na=fingerprint:sha-256 11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11:11\\r\\na=setup:active\\r\\na=mid:0\\r\\na=sendrecv\\r\\na=rtcp-mux\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/mesh/answer",
          "protocol": "http",
          "host": ["{{base_url}}"],
          "path": ["mesh", "answer"]
        },
        "description": "Отправить SDP answer от получателя к инициатору"
      },
      "response": []
    },
    {
      "name": "4. Add ICE Candidate",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-CSRF-Token",
            "value": "{{csrf_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"peer_id\": \"peer_123456\",\n  \"candidate\": \"candidate:842163049 1 udp 1677729535 192.168.1.1 54321 typ srflx raddr 192.168.1.1 rport 54321 generation 0 ufrag abcd network-cost 999\",\n  \"sdp_mline_index\": 0,\n  \"sdp_mid\": \"0\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/mesh/ice-candidate",
          "protocol": "http",
          "host": ["{{base_url}}"],
          "path": ["mesh", "ice-candidate"]
        },
        "description": "Добавить ICE candidate для NAT traversal"
      },
      "response": []
    },
    {
      "name": "5. Mark Connected",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-CSRF-Token",
            "value": "{{csrf_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"peer_id\": \"peer_123456\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/mesh/connected",
          "protocol": "http",
          "host": ["{{base_url}}"],
          "path": ["mesh", "connected"]
        },
        "description": "Пометить соединение как успешно установленное (проверяет topology)"
      },
      "response": []
    },
    {
      "name": "6. Mark Failed",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-CSRF-Token",
            "value": "{{csrf_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"peer_id\": \"peer_123456\",\n  \"reason\": \"ICE connection failed after 30 seconds\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/mesh/failed",
          "protocol": "http",
          "host": ["{{base_url}}"],
          "path": ["mesh", "failed"]
        },
        "description": "Пометить соединение как ошибочное"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "csrf_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "stream_id",
      "value": "1",
      "type": "string"
    }
  ]
}
